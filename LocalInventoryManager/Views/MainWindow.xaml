<Window x:Class="LocalInventoryManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Local Inventory Analytics Manager"
        Height="900"
        Width="1600"
        WindowStartupLocation="Manual"
        Loaded="Window_Loaded"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        Background="#F5F7FB">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="340"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT PANEL -->
        <Border Grid.Column="0"
                Background="#031633">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="80"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="100"/>
                </Grid.RowDefinitions>

                <TextBlock Text="LOCAL INVENTORY ANALYTICS MANAGER"
                           Foreground="White"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="20"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Row="1"
                            Margin="20">

                    <TextBlock Text="PANEL A: METRICS"
                               Foreground="White"
                               FontSize="18"
                               Margin="0,0,0,20"/>

                    <Border Background="#0C2145"
                            CornerRadius="15"
                            Padding="20"
                            Margin="0,0,0,20">

                        <StackPanel>

                            <TextBlock Text="TOTAL ASSET VALUE"
                                       Foreground="White"
                                       FontSize="14"/>

                            <TextBlock Text="{Binding TotalAssetValue, StringFormat=R {0:N2}}"
                                       Foreground="#1FE39A"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       Margin="0,10,0,0"/>

                        </StackPanel>

                    </Border>

                    <Border Background="#0C2145"
                            CornerRadius="15"
                            Padding="20"
                            Margin="0,0,0,20">

                        <StackPanel>

                            <TextBlock Text="TOTAL STOCK UNITS"
                                       Foreground="White"
                                       FontSize="14"/>

                            <TextBlock Text="{Binding TotalStockUnits, StringFormat={}{0} Units}"
                                       Foreground="White"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       Margin="0,10,0,0"/>

                        </StackPanel>

                    </Border>

                    <Border Background="#4A2035"
                            CornerRadius="15"
                            Padding="20">

                        <StackPanel>

                            <TextBlock Text="LOW STOCK ALERTS"
                                       Foreground="White"
                                       FontSize="14"/>

                            <TextBlock Text="{Binding LowStockCount, StringFormat={}{0} Items}"
                                       Foreground="White"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       Margin="0,10,0,0"/>

                        </StackPanel>

                    </Border>

                </StackPanel>

                <TextBlock Grid.Row="2"
                           Text="Last Updated"
                           Foreground="White"
                           Margin="20"
                           VerticalAlignment="Center"/>

            </Grid>

        </Border>

        <!-- CENTER PANEL -->
        <Border Grid.Column="1"
                Margin="10"
                Background="White"
                CornerRadius="15">

            <Grid Margin="20">

                <Grid.RowDefinitions>
                    <RowDefinition Height="80"/>
                    <RowDefinition Height="60"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="170"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>

                        <TextBlock Text="Inventory Dashboard"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="#1E293B"/>

                        <TextBlock Text="Monitor stock levels and manage products"
                   Foreground="#64748B"/>

                    </StackPanel>

                    <Button Grid.Column="1"
            Content="Edit Product"
            Height="45"
            Width="125"
            Margin="0,0,10,0"
            HorizontalAlignment="Right"
            Background="White"
            BorderBrush="#CBD5E1"
            BorderThickness="1"
            FontWeight="SemiBold"
            Cursor="Hand"
            Click="EditProduct_Click"/>

                    <Button Grid.Column="2"
            Content="New Product"
            Height="45"
            Width="150"
            Background="#2563EB"
            Foreground="White"
            BorderThickness="0"
            FontWeight="SemiBold"
            Cursor="Hand"
            HorizontalAlignment="Right"
            Click="NewProduct_Click"/>

                </Grid>

                <TextBox Grid.Row="1"
                         Padding="10"
                         FontSize="15"
                         VerticalContentAlignment="Center"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>

                <DataGrid Grid.Row="2"
                          ItemsSource="{Binding Products}"
                          SelectedItem="{Binding SelectedProduct, Mode=TwoWay}"
                          Margin="0,10,0,0"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="SKU"
                                            Binding="{Binding Sku}"
                                            Width="120"/>

                        <DataGridTextColumn Header="Product Name"
                                            Binding="{Binding ProductName}"
                                            Width="*"/>

                        <DataGridTextColumn Header="Quantity"
                                            Binding="{Binding Quantity}"
                                            Width="120"/>

                        <DataGridTextColumn Header="Price"
                                            Binding="{Binding Price}"
                                            Width="120"/>

                        <DataGridTextColumn Header="Low Threshold"
                                            Binding="{Binding LowStockThreshold}"
                                            Width="130"/>

                        <DataGridTextColumn Header="Status"
                                            Binding="{Binding Status}"
                                            Width="100"/>

                    </DataGrid.Columns>

                </DataGrid>

            </Grid>

        </Border>

        <!-- RIGHT PANEL -->
        <Border Grid.Column="2"
                Margin="10"
                Background="White"
                CornerRadius="15">

            <ScrollViewer>

                <StackPanel Margin="20">

                    <TextBlock Text="PRODUCT PROFILE"
                               FontSize="22"
                               FontWeight="Bold"
                               Margin="0,0,0,20"/>

                    <TextBlock Text="SKU"/>
                    <TextBox Height="35"
                             Text="{Binding SelectedProduct.Sku, Mode=TwoWay}"/>

                    <TextBlock Text="Product Name"
                               Margin="0,15,0,5"/>
                    <TextBox Height="35"
                             Text="{Binding SelectedProduct.ProductName, Mode=TwoWay}"/>

                    <TextBlock Text="Unit Price"
                               Margin="0,15,0,5"/>
                    <TextBox Height="35"
                             Text="{Binding SelectedProduct.Price, Mode=TwoWay}"/>

                    <TextBlock Text="Stock Quantity"
                               Margin="0,15,0,5"/>
                    <TextBox Height="35"
                             Text="{Binding SelectedProduct.Quantity, Mode=TwoWay}"/>

                    <TextBlock Text="Low Stock Threshold"
                               Margin="0,15,0,5"/>
                    <TextBox Height="35"
                             Text="{Binding SelectedProduct.LowStockThreshold, Mode=TwoWay}"/>

                    <Grid Margin="0,30,0,0">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                            Content="Delete Product"
                            Height="45"
                            Margin="0,0,8,0"
                            Background="White"
                            BorderBrush="#CBD5E1"
                            BorderThickness="1"
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            Click="DeleteProduct_Click"/>

                                        <Button Grid.Column="1"
                            Content="Save Product"
                            Height="45"
                            Margin="8,0,0,0"
                            Background="#2563EB"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            Click="SaveProduct_Click"/>

                    </Grid>

                </StackPanel>

            </ScrollViewer>

        </Border>

    </Grid>

</Window>